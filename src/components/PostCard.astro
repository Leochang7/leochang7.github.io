---
const { title, description, href = "#", date, tags = [] } = Astro.props;
---

<article class="post-card">
  <a href={href}>
    <span>{date}</span>
    <h2>{title}</h2>
    {description && <p>{description}</p>}
    {tags.length > 0 && (
      <ul class="tag-list" aria-label="文章标签">
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
    )}
  </a>
</article>
