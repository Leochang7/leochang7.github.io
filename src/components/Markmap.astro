---
const { source = "", title = "思维导图" } = Astro.props;
---

<figure class="markmap-frame">
  <svg class="markmap-svg" role="img" aria-label={title}></svg>
  <script type="text/plain" data-markmap-source>{source}</script>
</figure>

<script is:inline type="module">
  const [{ Transformer }, { Markmap }] = await Promise.all([
    import("https://cdn.jsdelivr.net/npm/markmap-lib@0.18.12/+esm"),
    import("https://cdn.jsdelivr.net/npm/markmap-view@0.18.12/+esm"),
  ]);

  const transformer = new Transformer();

  document.querySelectorAll(".markmap-frame").forEach((frame) => {
    if (frame.hasAttribute("data-rendered")) return;

    const source = frame.querySelector("[data-markmap-source]")?.textContent ?? "";
    const svg = frame.querySelector("svg");
    if (!svg || source.trim().length === 0) return;

    const { root } = transformer.transform(source);
    Markmap.create(svg, { autoFit: true, duration: 250 }, root);
    frame.setAttribute("data-rendered", "true");
  });
</script>
