---
const { groups = [] } = Astro.props;
---

<div class="link-layout">
  <section class="link-groups" aria-label="链接集合">
    {groups.map((group) => (
      <section id={group.id}>
        <h2>{group.title}</h2>
        <p>
          {group.links.map((link, index) => (
            <>
              {index > 0 && " | "}
              <a href={link.href}>{link.label}</a>
            </>
          ))}
        </p>
      </section>
    ))}
  </section>

  <aside class="link-toc" aria-label="页面目录">
    {groups.map((group) => <a href={`#${group.id}`}>{group.title}</a>)}
  </aside>
</div>
