---
import BaseLayout from "../layouts/BaseLayout.astro";
import LinkCollection from "../themes/academic-minimal/components/LinkCollection.astro";

const groups = [
  {
    id: "paper-writing",
    title: "论文写作",
    links: [
      { href: "https://www.overleaf.com/learn", label: "Overleaf Learn" },
      { href: "https://www.latex-project.org/help/documentation/", label: "LaTeX Documentation" },
      { href: "https://arxiv.org/", label: "arXiv" },
    ],
  },
  {
    id: "bibliography",
    title: "文献收集",
    links: [
      { href: "https://www.zotero.org/", label: "Zotero" },
      { href: "https://scholar.google.com/", label: "Google Scholar" },
    ],
  },
  {
    id: "daily-papers",
    title: "Daily Papers",
    links: [
      { href: "https://arxiv.org/list/cs.LG/recent", label: "cs.LG recent" },
      { href: "https://arxiv.org/list/cs.NI/recent", label: "cs.NI recent" },
    ],
  },
  {
    id: "conference",
    title: "Conference proceedings",
    links: [
      { href: "https://dl.acm.org/", label: "ACM Digital Library" },
      { href: "https://www.usenix.org/publications/proceedings", label: "USENIX Proceedings" },
      { href: "https://ieeexplore.ieee.org/", label: "IEEE Xplore" },
    ],
  },
  {
    id: "study",
    title: "Study materials",
    links: [
      { href: "https://missing.csail.mit.edu/", label: "Missing Semester" },
      { href: "https://teachyourselfcs.com/", label: "Teach Yourself CS" },
    ],
  },
];
---

<BaseLayout title="杂项" description="论文写作、文献收集和学习资料链接。">
  <main class="page">
    <LinkCollection groups={groups} />
  </main>
</BaseLayout>
