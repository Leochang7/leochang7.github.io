---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleList from "../../themes/academic-minimal/components/ArticleList.astro";
import { getTagGroups } from "../../lib/posts";

export async function getStaticPaths() {
  const tags = await getTagGroups();

  return tags.map(({ tag, posts }) => ({
    params: { tag },
    props: { tag, posts },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`标签：${tag}`} description={`标签 ${tag} 下的文章。`}>
  <main class="page">
    <section class="prose">
      <p class="eyebrow">Tag</p>
      <h1>{tag}</h1>
      <p>共 {posts.length} 篇文章。</p>
    </section>

    <ArticleList posts={posts} />
  </main>
</BaseLayout>
