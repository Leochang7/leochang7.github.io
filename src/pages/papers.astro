---
import BaseLayout from "../layouts/BaseLayout.astro";
import PDFViewer from "../components/PDFViewer.astro";
---

<BaseLayout title="资料" description="论文、简历和 PDF 资料展示。">
  <main class="page">
    <section class="prose">
      <h1>资料</h1>
      <p>这里用于集中展示论文、简历和其他 PDF 资料。</p>
    </section>

    <section class="paper-list" aria-label="PDF 资料列表">
      <article class="paper-item">
        <div>
          <p class="eyebrow">PDF</p>
          <h2>PDF 预览示例</h2>
          <p>用于验证站点内嵌 PDF、下载和外部打开能力。</p>
        </div>
        <PDFViewer file="/pdfs/sample.pdf" title="PDF 预览示例" />
      </article>
    </section>
  </main>
</BaseLayout>
