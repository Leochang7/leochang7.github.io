---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleList from "../themes/academic-minimal/components/ArticleList.astro";
import { getPublishedPosts } from "../lib/posts";

const posts = await getPublishedPosts();
---

<BaseLayout title="归档" description="按年份浏览全部文章。">
  <main class="page">
    <section class="prose">
      <h1>归档</h1>
      <p>按时间回看所有文章。</p>
    </section>

    <ArticleList posts={posts} />
  </main>
</BaseLayout>
