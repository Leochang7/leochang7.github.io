---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimelineList from "../themes/academic-minimal/components/TimelineList.astro";

const items = [
  {
    date: "2026/06/18",
    title: "博客系统搭建",
    body: "完成 Astro、Markdown、MDX、LaTeX、PDF、图表、RSS、sitemap 和 GitHub Pages 部署。",
  },
  {
    date: "2026/06/18",
    title: "自定义主题规划",
    body: "确定 academic-minimal 主题方向：白底、居中导航、窄正文、普通链接、内容优先。",
  },
  {
    date: "2026/06/18",
    title: "主题样式迁移",
    body: "将站点视觉层拆入 src/themes/academic-minimal。",
    code: `src/themes/academic-minimal/
  theme.css
  config.ts
  components/`,
  },
];
---

<BaseLayout title="历程" description="站点更新和个人记录。">
  <main class="page">
    <TimelineList items={items} />
  </main>
</BaseLayout>
